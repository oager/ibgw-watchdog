[Unit]
Description=IB Gateway via IBC (paper, port 4002)
Wants=network-online.target
After=network-online.target graphical-session.target
StartLimitIntervalSec=0

[Service]
Type=simple
Environment=DISPLAY=:0
Environment=XAUTHORITY=/run/user/1000/gdm/Xauthority
ExecStartPre=/bin/bash -c 'for i in $(seq 1 30); do [ -e /tmp/.X11-unix/X0 ] && exit 0; sleep 1; done; exit 0'
ExecStart=/home/oager/ibc/gatewaystart.sh -inline
Restart=on-failure
RestartSec=30

[Install]
WantedBy=default.target
